{
  "name": "@umami/kaze",
  "version": "0.1.0",
  "description": "Standalone layout primitives powered by Tailwind CSS",
  "homepage": "https://github.com/umami-software/react-zen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/umami-software/react-zen.git"
  },
  "license": "MIT",
  "author": "Umami <hello@umami.is>",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "styles.css",
    "styles.full.css",
    "tailwind.preset.ts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./styles.css",
    "./styles.full.css": "./styles.full.css",
    "./tailwind-preset": "./tailwind.preset.ts"
  },
  "scripts": {
    "build": "npm-run-all tsup css",
    "lint": "biome check ./src",
    "css": "node css.mjs",
    "tsup": "tsup"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.4.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.7",
    "@tailwindcss/cli": "^4.1.18",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.23",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
